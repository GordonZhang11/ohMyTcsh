#!/usr/bin/env tcsh

# SPDX-License-Identifier: BSD-3-Clause

#  ==================================================
#  OMT Plugin omtAliases: Shortcuts for daily operations
#  Copyright 2026 Gordon Zhang
#  ==================================================

omtAlias ll  "ls -lh"
omtAlias la  "ls -alh"
omtAlias lr  "ls -R"

omtAlias ..  "cd .."
omtAlias ... "cd ../.."
omtAlias -   "cd -"

omtAlias h   "history"

omtAlias dh  "df -h"
omtAlias ds  "du -sh"

